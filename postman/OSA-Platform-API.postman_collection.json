{
	"info": {
		"_postman_id": "osa-platform-api-collection",
		"name": "OSA Community Platform API",
		"description": "Complete API collection for The Odisha Society of the Americas platform.\n\n## Authentication\nMost endpoints require Bearer token authentication. You'll need to:\n1. Sign up via Supabase Auth (Google/Microsoft OAuth)\n2. Get your access token from Supabase\n3. Set it in the environment variable `auth_token`\n\n## Workflow\n1. **Setup**: Get auth token and create profile\n2. **Memberships**: Browse types, apply for membership\n3. **Payments**: Handle payment processing\n4. **Admin**: Manage users, approve memberships (requires ADMIN role)\n\n## Base URL\n`http://localhost:3001/api`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Users",
			"item": [
				{
					"name": "Get Current User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('user_id', response.id);",
									"    pm.environment.set('user_role', response.role);",
									"    console.log('User ID:', response.id);",
									"    console.log('Role:', response.role);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users/me",
							"host": ["{{base_url}}"],
							"path": ["users", "me"]
						},
						"description": "Get the authenticated user's information. Triggers JIT (Just-In-Time) sync from Supabase Auth."
					},
					"response": []
				},
				{
					"name": "Create Profile",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201 || pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.profile) {",
									"        pm.environment.set('profile_id', response.profile.id);",
									"        console.log('Profile created:', response.profile.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+15551234567\",\n  \"address\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"San Francisco\",\n    \"state\": \"CA\",\n    \"zip\": \"94102\",\n    \"country\": \"USA\"\n  },\n  \"dateOfBirth\": \"1990-01-01\",\n  \"gender\": \"MALE\",\n  \"bio\": \"Member of OSA community\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/me/profile",
							"host": ["{{base_url}}"],
							"path": ["users", "me", "profile"]
						},
						"description": "Create a profile for the current user. **Required before applying for membership.**"
					},
					"response": []
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"phone\": \"+15559876543\",\n  \"bio\": \"Updated bio information\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/me/profile",
							"host": ["{{base_url}}"],
							"path": ["users", "me", "profile"]
						},
						"description": "Update the current user's profile. Partial updates are supported."
					},
					"response": []
				},
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users/me/profile",
							"host": ["{{base_url}}"],
							"path": ["users", "me", "profile"]
						},
						"description": "Get the current user's profile information."
					},
					"response": []
				},
				{
					"name": "Export My Data (GDPR)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users/me/export",
							"host": ["{{base_url}}"],
							"path": ["users", "me", "export"]
						},
						"description": "Export all data associated with the current user (GDPR compliance)."
					},
					"response": []
				},
				{
					"name": "Soft Delete Account",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users/me",
							"host": ["{{base_url}}"],
							"path": ["users", "me"]
						},
						"description": "Soft delete the current user's account. Data is marked as deleted but not permanently removed."
					},
					"response": []
				},
				{
					"name": "[Admin] List All Users",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users",
							"host": ["{{base_url}}"],
							"path": ["users"]
						},
						"description": "**Admin only.** List all users in the system."
					},
					"response": []
				},
				{
					"name": "[Admin] Get User by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users/{{target_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["users", "{{target_user_id}}"]
						},
						"description": "**Admin only.** Get a specific user by ID."
					},
					"response": []
				},
				{
					"name": "[Admin] Change User Role",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role\": \"MEMBER\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/{{target_user_id}}/role",
							"host": ["{{base_url}}"],
							"path": ["users", "{{target_user_id}}", "role"]
						},
						"description": "**Admin only.** Change a user's role. Valid roles: GUEST, MEMBER, CONTRIBUTOR, ADMIN."
					},
					"response": []
				},
				{
					"name": "[Admin] Delete User",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users/{{target_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["users", "{{target_user_id}}"]
						},
						"description": "**Admin only.** Permanently delete a user."
					},
					"response": []
				}
			],
			"description": "User management endpoints for profile creation, updates, and admin operations."
		},
		{
			"name": "Memberships",
			"item": [
				{
					"name": "List Membership Types",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const types = pm.response.json();",
									"    if (types.length > 0) {",
									"        pm.environment.set('membership_type_id', types[0].id);",
									"        console.log('First membership type ID:', types[0].id);",
									"        console.log('Name:', types[0].name);",
									"        console.log('Price:', types[0].price);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/memberships/types",
							"host": ["{{base_url}}"],
							"path": ["memberships", "types"]
						},
						"description": "**Public endpoint.** List all available membership types (Individual, Family, Student, Lifetime)."
					},
					"response": []
				},
				{
					"name": "Get Membership Type by ID",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/memberships/types/{{membership_type_id}}",
							"host": ["{{base_url}}"],
							"path": ["memberships", "types", "{{membership_type_id}}"]
						},
						"description": "**Public endpoint.** Get details of a specific membership type."
					},
					"response": []
				},
				{
					"name": "Apply for Membership",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const membership = pm.response.json();",
									"    pm.environment.set('membership_id', membership.id);",
									"    pm.environment.set('membership_status', membership.status);",
									"    console.log('Membership ID:', membership.id);",
									"    console.log('Status:', membership.status);",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Make sure we have a profile first",
									"if (!pm.environment.get('profile_id')) {",
									"    console.warn('⚠️ Profile not created yet. Create profile first!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"membershipTypeId\": \"{{membership_type_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/memberships",
							"host": ["{{base_url}}"],
							"path": ["memberships"]
						},
						"description": "Apply for a membership. **Requires profile to be created first.** Creates a PENDING membership that requires payment."
					},
					"response": []
				},
				{
					"name": "Get My Membership",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/memberships/me",
							"host": ["{{base_url}}"],
							"path": ["memberships", "me"]
						},
						"description": "Get the current user's active membership. Returns 204 No Content if no active membership exists."
					},
					"response": []
				},
				{
					"name": "Get My Membership History",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/memberships/me/history",
							"host": ["{{base_url}}"],
							"path": ["memberships", "me", "history"]
						},
						"description": "Get the current user's membership history (all past and current memberships)."
					},
					"response": []
				},
				{
					"name": "Cancel My Membership",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/memberships/me",
							"host": ["{{base_url}}"],
							"path": ["memberships", "me"]
						},
						"description": "Cancel the current user's active membership. Sets status to CANCELLED."
					},
					"response": []
				},
				{
					"name": "[Admin] List All Memberships",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/memberships",
							"host": ["{{base_url}}"],
							"path": ["memberships"]
						},
						"description": "**Admin only.** List all memberships in the system."
					},
					"response": []
				},
				{
					"name": "[Admin] Get Membership by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/memberships/{{membership_id}}",
							"host": ["{{base_url}}"],
							"path": ["memberships", "{{membership_id}}"]
						},
						"description": "**Admin only.** Get a specific membership by ID."
					},
					"response": []
				},
				{
					"name": "[Admin] Approve Membership",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"note\": \"Approved after payment verification\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/memberships/{{membership_id}}/approve",
							"host": ["{{base_url}}"],
							"path": ["memberships", "{{membership_id}}", "approve"]
						},
						"description": "**Admin only.** Approve a pending membership. Changes status to ACTIVE and promotes user to MEMBER role."
					},
					"response": []
				},
				{
					"name": "[Admin] Update Membership Status",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"ACTIVE\",\n  \"note\": \"Status updated by admin\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/memberships/{{membership_id}}/status",
							"host": ["{{base_url}}"],
							"path": ["memberships", "{{membership_id}}", "status"]
						},
						"description": "**Admin only.** Update membership status. Valid statuses: PENDING, ACTIVE, EXPIRED, CANCELLED."
					},
					"response": []
				},
				{
					"name": "[Admin] Grant Honorary Membership",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"userId\": \"{{target_user_id}}\",\n  \"note\": \"Honorary membership for community contributions\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/memberships/honorary",
							"host": ["{{base_url}}"],
							"path": ["memberships", "honorary"]
						},
						"description": "**Admin only.** Grant a free honorary membership to a user. User is immediately promoted to MEMBER role."
					},
					"response": []
				},
				{
					"name": "[Admin] Check Available Credit",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/memberships/credit/{{target_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["memberships", "credit", "{{target_user_id}}"]
						},
						"description": "**Admin only.** Check if a user has available membership credit from expired memberships (365-day window)."
					},
					"response": []
				}
			],
			"description": "Membership management endpoints for applying, viewing, and managing memberships."
		},
		{
			"name": "Payments",
			"item": [
				{
					"name": "Create Checkout Session",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('payment_id', response.id);",
									"    pm.environment.set('stripe_session_id', response.stripeSessionId);",
									"    console.log('Payment ID:', response.id);",
									"    console.log('Stripe Session ID:', response.stripeSessionId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"membershipId\": \"{{membership_id}}\",\n  \"successUrl\": \"http://localhost:3000/membership/success\",\n  \"cancelUrl\": \"http://localhost:3000/membership/cancel\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/payments/checkout-session",
							"host": ["{{base_url}}"],
							"path": ["payments", "checkout-session"]
						},
						"description": "Create a Stripe checkout session for membership payment. Returns a Stripe session URL to redirect the user to."
					},
					"response": []
				},
				{
					"name": "Get My Payment History",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/payments/me",
							"host": ["{{base_url}}"],
							"path": ["payments", "me"]
						},
						"description": "Get the current user's payment history."
					},
					"response": []
				},
				{
					"name": "Stripe Webhook",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "stripe-signature",
								"value": "{{stripe_webhook_signature}}",
								"description": "Stripe webhook signature for verification"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"type\": \"checkout.session.completed\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"cs_test_...\",\n      \"payment_status\": \"paid\"\n    }\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/payments/webhook",
							"host": ["{{base_url}}"],
							"path": ["payments", "webhook"]
						},
						"description": "**Webhook endpoint.** Receives payment events from Stripe. Automatically approves memberships on successful payment."
					},
					"response": []
				},
				{
					"name": "[Admin] List All Payments",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/payments",
							"host": ["{{base_url}}"],
							"path": ["payments"]
						},
						"description": "**Admin only.** List all payments in the system."
					},
					"response": []
				},
				{
					"name": "[Admin] Get Payment by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/payments/{{payment_id}}",
							"host": ["{{base_url}}"],
							"path": ["payments", "{{payment_id}}"]
						},
						"description": "**Admin only.** Get a specific payment by ID."
					},
					"response": []
				},
				{
					"name": "[Admin] Override Payment Amount",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 2500,\n  \"note\": \"Discounted rate for early bird signup\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/payments/{{payment_id}}",
							"host": ["{{base_url}}"],
							"path": ["payments", "{{payment_id}}"]
						},
						"description": "**Admin only.** Override the payment amount for a membership. Amount is in cents (e.g., 2500 = $25.00)."
					},
					"response": []
				}
			],
			"description": "Payment processing endpoints for Stripe integration and payment management."
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3001/api",
			"type": "string"
		}
	]
}
